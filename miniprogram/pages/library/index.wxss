page { background-color: #F8F9FA; }
.container { padding: 40rpx; }
.header-bar { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  margin-bottom: 40rpx;
}
.page-title { 
  font-size: 40rpx; 
  font-weight: bold; 
}
.add-btn { 
  background: #333; 
  color: white; 
  font-size: 26rpx; 
  padding: 10rpx 30rpx; 
  border-radius: 40rpx; 
  margin: 0 !important; 
}
.list-item { 
  background: #FFF; 
  padding: 30rpx; 
  border-radius: 16rpx; 
  margin-bottom: 24rpx; 
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.item-name { font-size: 32rpx; font-weight: 500;}
.item-cat { font-size: 24rpx; color: #999; background: #EEE; padding: 4rpx 16rpx; border-radius: 20rpx; }
.empty { margin-top: 100rpx; text-align: center; color: #888; }
