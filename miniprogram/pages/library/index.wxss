/* Remove individual page background */
.container { padding: 40rpx; }
.header-bar { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  margin-bottom: 40rpx;
}
.page-title { 
  font-size: 40rpx; 
  font-weight: 900; 
  color: #2D2D2D;
}
.add-btn { 
  background: #333333; 
  color: white; 
  font-size: 26rpx; 
  padding: 10rpx 30rpx; 
  border-radius: 40rpx; 
  margin: 0 !important; 
  box-shadow: 4rpx 6rpx 0px #DEDBD3; /* 萌态贴纸阴影 */
}
.list-item { 
  background: #FFF; 
  padding: 30rpx; 
  border-radius: 24rpx; 
  margin-bottom: 30rpx; 
  border: 4rpx solid #333;
  box-shadow: 4rpx 6rpx 0px rgba(0,0,0,0.08); /* 手账阴影 */
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.item-name { font-size: 34rpx; font-weight: 900; color: #2D2D2D;}
.item-cat { font-size: 24rpx; color: #333; border: 3rpx solid #333; font-weight: bold; background: #FFEDF1; padding: 4rpx 16rpx; border-radius: 20rpx; }
.empty { margin-top: 100rpx; text-align: center; color: #888; }
