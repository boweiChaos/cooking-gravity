<view class="container">
  <view class="header">
    <view class="date-nav">
      <view class="nav-btn" bindtap="prevDay">◄ 前一天</view>
      <text class="date">{{dateLabel}}</text>
      <view class="nav-btn" bindtap="nextDay">后一天 ►</view>
    </view>
    <text class="title">{{titleText}} 🍱</text>
  </view>

  <!-- 如果有菜单 -->
  <view class="menu-list" wx:if="{{menuList.length > 0}}">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
      <view class="info">
        <text class="name">{{item.name}}</text>
        <text class="tags">{{item.category}}</text>
      </view>
    </view>
  </view>

  <!-- 暂无菜单 -->
  <view class="empty" wx:else>
    <view class="empty-icon">🍽</view>
    <text>老婆大人还没决定吃啥哦～</text>
  </view>

  <!-- 管理员可见入口 -->
  <view class="admin-actions" wx:if="{{isAdmin}}">
    <button class="btn btn-primary" bindtap="goToLibrary">进入菜谱库选菜</button>
  </view>
  <view class="admin-actions" wx:else>
     <!-- <button class="btn btn-secondary">呼叫老婆上菜谱</button> -->
  </view>
</view>
