<view class="container">
  <view class="header">
    <view class="greeting" wx:if="{{roleName}}">
      <view class="user-badge">{{roleName}}</view>
      <text class="welcome-text" wx:if="{{roleName === '👸 老婆大人'}}">，今天想吃点啥？</text>
      <text class="welcome-text" wx:elif="{{roleName === '🤵‍♂️ 长工老公'}}">，还不快去买菜！</text>
      <text class="welcome-text" wx:else>，欢迎光临寒舍！</text>
    </view>
    
    <view class="date-nav">
      <view class="nav-btn" bindtap="prevDay">◄ 前一</view>
      
      <picker mode="date" value="{{currentDateStr}}" bindchange="onDatePick">
        <view class="date-picker-trigger">
          <text class="date">{{dateLabel}}</text>
          <text class="calendar-icon">📅</text>
        </view>
      </picker>

      <view class="nav-btn" bindtap="nextDay">后一 ►</view>
    </view>
    <text class="title">{{titleText}} 🍱</text>
  </view>

  <!-- 如果有菜单 -->
  <view class="menu-list" wx:if="{{menuList.length > 0}}">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
      <view class="info">
        <text class="name">{{item.name}}</text>
        <text class="tags">{{item.category}}</text>
      </view>
    </view>
  </view>

  <!-- 暂无菜单 -->
  <view class="empty" wx:else>
    <view class="empty-icon">🍽</view>
    <text>老婆大人还没决定吃啥哦～</text>
  </view>

  <!-- 所有人都可见入口 -->
  <view class="admin-actions">
    <button class="btn btn-primary" bindtap="goToLibrary">进入菜谱库选菜</button>
  </view>
</view>
