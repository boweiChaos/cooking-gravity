/* Remove individual page background to let the global grid show through */
.container { 
  padding: 40rpx; 
}
.header { 
  margin-bottom: 60rpx; 
  padding-top: 10rpx;
}
.greeting {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.user-badge {
  background: #FFF;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  border: 3rpx solid #333; /* 核心：加粗手绘感边框 */
  box-shadow: 4rpx 4rpx 0px rgba(0,0,0,0.1);
}
.welcome-text {
  font-size: 28rpx;
  color: #999;
  margin-left: 10rpx;
  font-weight: 500;
}
.date-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.nav-btn {
  font-size: 26rpx;
  color: #333;
  background: #FFF;
  border: 3rpx solid #333;
  box-shadow: 2rpx 4rpx 0px rgba(0,0,0,0.1);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-weight: bold;
}
.date-picker-trigger {
  display: flex;
  align-items: center;
  background: #FFF; 
  border: 3rpx solid #333;
  box-shadow: 4rpx 6rpx 0px rgba(0,0,0,0.1);
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
}
.date { 
  font-size: 30rpx; 
  color: #333; 
  font-weight: 900;
}
.calendar-icon {
  font-size: 28rpx;
  margin-left: 8rpx;
}
.title { 
  font-size: 56rpx; 
  font-weight: 800; 
  margin-top: 10rpx; 
  display: block;
  color: #333;
}
.empty { 
  text-align: center; 
  color: #999; 
  margin-top: 200rpx; 
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}
.admin-actions { 
  position: fixed; 
  bottom: 80rpx; 
  left: 40rpx; 
  right: 40rpx; 
}
.btn-primary { 
  background: #333333 !important; 
  color: #fff !important; 
  width: 100% !important; 
  border-radius: 60rpx; 
  font-size: 34rpx;
  font-weight: bold;
  padding: 24rpx 0;
  box-shadow: 6rpx 8rpx 0px #DEDBD3; /* 萌态贴纸阴影 */
}
.menu-item {
  background: #FFF;
  border: 4rpx solid #333;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 35rpx;
  /* 手帐本特有的小阴影 */
  box-shadow: 4rpx 6rpx 0px rgba(0,0,0,0.08); 
  display: flex;
  align-items: center;
}
.info .name {
  font-size: 40rpx;
  font-weight: 900;
  display: block;
  color: #2D2D2D;
  letter-spacing: 2rpx;
}
.info .tags {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  background: #FFEDF1;
  border: 3rpx solid #333;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  margin-top: 16rpx;
  display: inline-block;
}
