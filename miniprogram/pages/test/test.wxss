.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #07c160;
  padding-left: 20rpx;
}

.btn {
  margin-bottom: 30rpx !important;
  width: 100% !important;
  font-weight: normal;
}

.result-box {
  background: #f7f7f7;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
  border: 1px solid #eee;
  font-size: 28rpx;
  color: #333;
}

.preview-img {
  width: 100%;
  height: 350rpx;
  margin-top: 20rpx;
  background-color: #f1f1f1;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
  margin-bottom: 15rpx;
}
