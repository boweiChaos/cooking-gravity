<scroll-view scroll-y style="height: calc(100vh - 180rpx);" class="container">
  
  <view class="section">
    <view class="sec-title">1. 基本信息</view>
    <view class="form-item">
      <text class="label">菜名</text>
      <input class="input" placeholder="例如：红烧肉" value="{{name}}" bindinput="onNameInput"/>
    </view>
    <view class="form-item">
      <text class="label">分类</text>
      <picker mode="selector" style="flex: 1; height: 100%; min-height: 60rpx;" bindchange="onCatChange" value="{{catIndex}}" range="{{categories}}">
        <view style="width: 100%; height: 100%; display: flex; justify-content: space-between; align-items: center;">
          <text class="picker-val">{{categories[catIndex]}}</text>
          <text style="color: #666; font-size: 26rpx; background: #eee; padding: 4rpx 12rpx; border-radius: 8rpx;">点击切换 ></text>
        </view>
      </picker>
    </view>
    <view class="form-item" style="border-bottom: none;">
      <text class="label">小红书</text>
      <input class="input" placeholder="粘贴小红书笔记链接 (选填)" value="{{xhsLink}}" bindinput="onXhsLinkInput"/>
    </view>
  </view>

  <view class="section">
    <view class="sec-title">2. 照片秀 (选填)</view>
    <view class="img-grid">
      <view class="img-box" wx:for="{{images}}" wx:key="*this">
        <image class="photo" src="{{item}}" mode="aspectFill"></image>
        <view class="del-btn" bindtap="deleteImage" data-idx="{{index}}">×</view>
      </view>
      <view class="add-img-box" bindtap="chooseImages" wx:if="{{images.length < 9}}">
        <text class="plus">+</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="sec-title">3. 原料清单 (老婆钦点)</view>
    <view class="array-list">
      <view class="row-item" wx:for="{{ingredients}}" wx:key="index">
        <input class="input small-input name-input" placeholder="食材 (如：排骨)" value="{{item.name}}" bindinput="onIngNameInput" data-idx="{{index}}"/>
        <input class="input small-input amount-input" placeholder="用量 (如：500g)" value="{{item.amount}}" bindinput="onIngAmountInput" data-idx="{{index}}"/>
        <view class="del-row" bindtap="delIngredient" data-idx="{{index}}">⛔️</view>
      </view>
      <view class="add-row-btn" bindtap="addIngredient">+ 添加食材</view>
    </view>
  </view>

  <view class="section">
    <view class="sec-title">4. 具体怎么搞 (步骤)</view>
    <view class="group-list">
      <view class="step-group" wx:for="{{stepGroups}}" wx:key="group-{{index}}">
        <view class="group-header">
          <input class="group-title-input" placeholder="分组名 (如：备菜)" value="{{item.title}}" bindinput="onGroupTitleInput" data-group-idx="{{index}}"/>
          <view class="del-group" bindtap="delGroup" data-group-idx="{{index}}" wx:if="{{stepGroups.length > 1}}">⛔️</view>
        </view>
        <view class="steps-in-group">
          <view class="step-item" wx:for="{{item.steps}}" wx:for-item="step" wx:for-index="stepIdx" wx:key="step-{{stepIdx}}">
            <view class="step-num">{{stepIdx + 1}}</view>
            <view class="step-input-wrapper">
              <textarea maxlength="500" auto-height class="input step-input" placeholder="描述具体做法..." value="{{step.desc}}" bindinput="onStepInput" data-group-idx="{{index}}" data-step-idx="{{stepIdx}}"></textarea>
              <view class="char-count">{{step.desc.length}}/500</view>
            </view>
            <view class="del-row" bindtap="delStep" data-group-idx="{{index}}" data-step-idx="{{stepIdx}}" wx:if="{{item.steps.length > 1}}">⛔️</view>
          </view>
        </view>
        <view class="add-step-in-group" bindtap="addStep" data-group-idx="{{index}}">+ 添加步骤</view>
      </view>
      <view class="add-group-btn" bindtap="addGroup">+ 添加分组</view>
    </view>
  </view>

  <view class="section">
    <view class="sec-title">5. 老婆给的锦囊 (注意事项)</view>
    <textarea auto-height class="input tips-input" placeholder="比如：盐少放点，肉多买点瘦的..." value="{{tips}}" bindinput="onTipsInput"></textarea>
  </view>

  <view class="bottom-space"></view>
</scroll-view>

<view class="footer-bar">
  <button class="submit-btn" bindtap="submit">发布到菜谱库</button>
</view>
