/* Remove individual page background */
.container { 
  box-sizing: border-box; 
  padding: 30rpx;
}
.section {
  background: #FFF;
  border-radius: 24rpx;
  border: 4rpx solid #333; /* 手绘笔记本边框 */
  box-shadow: 4rpx 6rpx 0px rgba(0,0,0,0.08); /* 手账阴影 */
  padding: 40rpx 30rpx;
  margin-bottom: 35rpx;
}
.sec-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #2D2D2D;
  margin-bottom: 30rpx;
  border-left: 8rpx solid #FF8BA7; /* 温暖的前缀 */
  padding-left: 16rpx;
}

/* 基础表单 */
.form-item {
  display: flex;
  align-items: center;
  border-bottom: 2rpx dashed #DDD;
  padding: 24rpx 0;
}
.form-item .label {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  width: 130rpx;
}
.form-item .input, .picker-val {
  flex: 1;
  font-size: 32rpx;
  color: #555;
}

/* 图片九宫格 */
.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.img-box, .add-img-box {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  border: 3rpx solid #333; /* 照片也加上硬边框 */
  position: relative;
  overflow: hidden;
}
.photo { width: 100%; height: 100%; }
.add-img-box {
  background: #F1F1F1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.plus { font-size: 80rpx; color: #CCC; font-weight: 200; }
.del-btn {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: #FFF;
  width: 40rpx;
  height: 40rpx;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
  border-bottom-left-radius: 16rpx;
}

/* 动态列表 - 原料 */
.row-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  align-items: center;
}
.small-input {
  background: #FFFDF8;
  border: 2rpx solid #333; /* 笔记本样式的边框 */
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}
.name-input { flex: 2; }
.amount-input { flex: 1; }
.del-row { font-size: 36rpx; color: #FF4444; padding: 10rpx;}
.add-row-btn {
  color: #333;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx 0;
  text-align: center;
  background: #FFF;
  border: 3rpx solid #333;
  box-shadow: 2rpx 4rpx 0px rgba(0,0,0,0.1);
  border-radius: 16rpx;
  margin-top: 10rpx;
}

/* 动态列表 - 步骤 */
.step-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
  align-items: flex-start;
}
.step-num {
  background: #FF8BA7;
  color: #FFF;
  border: 3rpx solid #333;
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx; /* 方形可爱的贴纸感 */
  text-align: center;
  line-height: 44rpx;
  font-size: 26rpx;
  font-weight: bold;
  margin-top: 10rpx;
}
.step-input {
  flex: 1;
  background: #FFFDF8;
  border: 2rpx solid #333;
  border-radius: 16rpx;
  padding: 20rpx;
  min-height: 80rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 杂项提示 */
.tips-input {
  background: #FFFBEC;
  border: 3rpx solid #FFC107;
  border-radius: 16rpx;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
  font-size: 28rpx;
  min-height: 120rpx;
}

/* 底部提交 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(253, 249, 241, 0.95);
  backdrop-filter: blur(10px);
  padding: 30rpx 40rpx 60rpx; /* 留出底部 safe-area 的空间 */
  border-top: 4rpx solid #333;
  box-sizing: border-box;
}
.submit-btn {
  background: #333333 !important;
  color: #FFF !important;
  border-radius: 60rpx !important;
  box-shadow: 6rpx 8rpx 0px #DEDBD3; /* 萌态贴纸阴影 */
  font-weight: bold;
  font-size: 34rpx;
}
.bottom-space { height: 80rpx; }
