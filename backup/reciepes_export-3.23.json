{"_id":"da3d566169bd1f8400de10085c276625","update_time":{"$date":"2026-03-21T10:24:47.078Z"},"_openid":"oQVJx3ZG20jRC_OLd9ag7_DiZYm4","create_time":{"$date":"2026-03-20T10:20:52.673Z"},"images":["cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774088685558_02skc.jpg"],"name":"红烧白萝卜","xhsLink":"","category":"素菜","ingredients":[{"amount":"1","name":"白萝卜"},{"amount":"1","name":"葱"},{"amount":"2瓣","name":"大蒜"},{"amount":"1片","name":"生姜"},{"amount":"1","name":"小米辣"}],"steps":[{"desc":"一、备菜\n1.辅料碟1:大蒜、生姜、小米辣、干辣椒切丁\n2.辅料碟2:葱花\n3.白萝卜切块，大小适中（不要切片，容易糊）"},{"desc":"二、烹饪\n1.小火爆香大蒜生姜小米辣\n2. 切好的萝卜放进去煸炒至微焦，加入一勺生抽一勺蚝油大半勺老抽\n3. 翻炒匀还可以加两颗冰糖进去一起炒，再加2小勺白糖\n4. 加入适量水（大概末过白萝卜2/3处）大火煮开以后转中小火慢慢煮，盖锅盖\n5.汤汁剩三分之一的时候加入适量鸡精（小半勺），转大火开始不停的翻炒收汁\n6.出锅前撒一些葱花"}],"tips":"白萝卜大小适中，不要切片，不然容易糊","stepGroups":[{"title":"备菜","steps":[{"desc":"辅料碟1:大蒜、生姜、小米辣、干辣椒切丁\n"},{"desc":"辅料碟2:葱花"},{"desc":"白萝卜切块，大小适中（不要切片，容易糊）"}]},{"steps":[{"desc":"小火爆香大蒜生姜小米辣"},{"desc":"切好的萝卜放进去煸炒至微焦，加入一勺生抽一勺蚝油大半勺老抽"},{"desc":"翻炒匀，加两颗冰糖进去一起炒，再加2小勺白糖"},{"desc":"加入适量水（大概末过白萝卜2/3处）大火煮开以后转中小火慢慢煮，盖锅盖"},{"desc":"汤汁剩三分之一的时候加入适量鸡精（小半勺），转大火开始不停的翻炒收汁"},{"desc":"出锅前撒一些葱花"}],"title":"烹饪"}]}
{"_id":"71fe4ab869be72bb0101cfc721e23ca2","_openid":"oQVJx3ZG20jRC_OLd9ag7_DiZYm4","category":"素菜","ingredients":[{"amount":"1～2颗","name":"佛手瓜"},{"amount":"1","name":"蒜瓣"},{"amount":"1根","name":"葱"},{"amount":"","name":"小米辣"},{"amount":"","name":"干辣椒"}],"name":"清炒佛手瓜","tips":"1）佛手瓜有粘液，必须带一次性手套接触\n2）如果想增加风味，炒菜时可以用猪油\n3）整个炒菜流程不宜过长，否则佛手瓜口感会过软","update_time":{"$date":"2026-03-21T14:16:00.987Z"},"xhsLink":"封闭在家第n天，吃什么？素炒佛手瓜！ 第一次见佛手瓜... http://xhslink.com/o/4uWfPmpqkDO  复制后打开【小红书】查看笔记！","create_time":{"$date":"2026-03-21T10:28:11.84Z"},"images":["cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774102559859_2ixjy.jpg","cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774102559862_zhjrw.jpg"],"stepGroups":[{"steps":[{"desc":"（戴手套）佛手瓜去皮、去核、切片，多清洗几遍"},{"desc":"小料碟：葱段（根部）、干辣椒、小米辣切丁"},{"desc":"小料碟2：蒜末"},{"desc":"小半碗水淀粉"}],"title":"备菜"},{"steps":[{"desc":"水开加盐和油\n佛手瓜焯水1分钟\n捞出过凉水备用"}],"title":"焯水"},{"steps":[{"desc":"热油下葱蒜小米椒炒香\n倒入佛手瓜，大火翻炒"},{"desc":"加一小勺盐，一小勺鸡精，继续翻炒"},{"desc":"加入水淀粉，翻炒收汁"},{"desc":"出锅前撒入蒜末，翻匀装盘即可"}],"title":"炒菜"}]}
{"_id":"33956e3d69be848101050eb01ec73a4a","_openid":"oQVJx3ZG20jRC_OLd9ag7_DiZYm4","category":"汤羹","create_time":{"$date":"2026-03-21T11:44:01.924Z"},"name":"番茄🍅牛尾骨汤","tips":"","xhsLink":"酸甜浓郁！过年做特别红火🤩 | 番茄牛尾汤🍅 之前在直... http://xhslink.com/o/7ux2iOIwqG8  复制后打开【小红书】查看笔记！","images":["cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774093440328_z2847.jpg","cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774093440332_y1kfo.jpg","cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774093440333_l8szj.jpg","cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774093440335_0hrho.jpg"],"ingredients":[{"amount":"500g","name":"牛尾骨"},{"amount":"1～2颗","name":"番茄"},{"name":"洋葱","amount":"半颗"},{"amount":"3片","name":"香叶"},{"amount":"2片","name":"生姜"},{"amount":"1根","name":"香菜"},{"amount":"","name":"朗姆酒"},{"amount":"","name":"辣酱油"},{"amount":"","name":"蕃茄酱"}],"stepGroups":[{"title":"备菜（至少距离饭点4.5h）","steps":[{"desc":"从冰箱拿出牛尾骨解冻\n牛尾骨放水里浸泡（2h）"},{"desc":"番茄、洋葱切片分开放置\n香菜洗干净切末\n姜片切片、香叶（可直接放入汤锅中）"}]},{"steps":[{"desc":"提前准备60度左右的水"},{"desc":"倒掉牛尾骨的血水，用厨房纸巾吸干多余水分"},{"desc":"热锅（不加油）、中小火，将牛尾骨煎得两面微黄"},{"desc":"将牛尾骨倒入汤锅，加入姜片、香叶2片和一瓶盖伏特加酒，倒入60度温水"},{"desc":"开大火煮沸，大约等待5-10min出沫，将沫撇干净后，转中小火、盖锅盖煮1h-1.5h（当中过来看一眼水没有煮干，水太少需要加水）"}],"title":"烹饪（距离饭点2.5h）"},{"steps":[{"desc":"炒番茄+洋葱浇头：热锅加油，放入番茄，翻炒1min后加入洋葱，加1勺盐、1勺糖，翻炒出香味和汁水"},{"desc":"将浇头倒入汤中，盖锅盖煮20min"},{"desc":"出锅前加入：一勺番茄酱（蕃茄酱自带甜味，如果是番茄膏可能还需要再加一些白砂糖）、两汤勺辣酱油\n尝味道，确认口味合适后加入香菜末、关火"}],"title":"加料（炖煮1h-1.5h后，距饭点40min）"}],"update_time":{"$date":"2026-03-21T15:33:17.195Z"}}
{"_id":"2d12bec269bea08e010e9c4d4e867570","ingredients":[{"amount":"大半颗","name":"白菜"},{"amount":"","name":"蒜末"},{"name":"干辣椒","amount":""},{"amount":"","name":"小米辣"}],"update_time":{"$date":"2026-03-21T16:45:14.288Z"},"xhsLink":"","category":"素菜","create_time":{"$date":"2026-03-21T13:43:42.147Z"},"images":["cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774100620720_mw54t.jpg"],"name":"酸辣白菜🥬","stepGroups":[{"steps":[{"desc":"白菜帮子和菜叶子分开切好放置"},{"desc":"小料碟：干辣椒剪段（干辣椒剪开时候里面的辣椒籽会漏出来，记得对着碟子剪）、小米辣丁、蒜末若干"}],"title":"备菜"},{"title":"烹饪","steps":[{"desc":"热油下小料碟（干辣椒丁，小米椒丁，蒜末翻炒香）"},{"desc":"加入白菜帮先炒1分钟，然后加入白菜叶子炒半分钟"},{"desc":"加入1.5勺生抽和1勺蚝油，翻炒均匀，然后再加入3小勺白糖，翻炒均匀"},{"desc":"沿着锅边，淋入2勺山西老陈醋，\n翻炒到白菜变软些了加入1/3勺盐🧂调味起锅"}]}],"tips":"","_openid":"oQVJx3ZG20jRC_OLd9ag7_DiZYm4"}
{"_id":"da3d566169bea4c30104db315ab0d01a","_openid":"oQVJx3ZG20jRC_OLd9ag7_DiZYm4","name":"酸辣土豆丝🥔","stepGroups":[{"steps":[{"desc":"土豆丝清洗一下，放在碗里加水加一勺白醋，浸泡20min（为了去淀粉），沥干后备用"},{"desc":"小料碟1：干辣椒剪段（干辣椒剪开时候里面的辣椒籽会漏出来，记得对着碟子剪）、小米辣丁、蒜末若干"},{"desc":"小料碟2：花椒粒（如后续不打算在烹饪过程中去掉的话可以并入小料碟1中）"},{"desc":"小料碟3：青椒丝"}],"title":"备菜"},{"steps":[{"desc":"热油下花椒粒、下小料碟（干辣椒丁，小米椒丁，蒜末翻炒香），激发出香味"},{"desc":"往锅中倒入沥干的土豆丝，转大火，快速翻炒约30秒-1分钟，让土豆丝均匀裹上油并略微变软"},{"desc":"调味，沿锅边淋入1勺生抽，1勺蚝油，2小勺白糖，翻炒均匀后淋入2勺锅边醋（陈醋），继续翻炒"},{"desc":"加入青椒，继续大火快速翻炒约30秒，使青椒断生但仍保持翠绿"},{"desc":"加入小半勺鸡精，翻炒均匀后出锅"}],"title":"新分组"}],"update_time":{"$date":"2026-03-21T16:46:28.42Z"},"category":"素菜","create_time":{"$date":"2026-03-21T14:01:39.165Z"},"images":["cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774101697631_opkq6.jpg"],"ingredients":[{"amount":"","name":"土豆丝（盒马/小象超市）"},{"amount":"","name":"青椒丝（土豆丝包配套）"},{"amount":"","name":"小米辣（小象超市配套）"},{"amount":"","name":"蒜末"},{"amount":"2根","name":"干辣椒"},{"amount":"十几颗","name":"花椒粒"}],"tips":"为何要泡白醋：有效去除淀粉，使土豆丝口感更脆\n花椒是否去除：如果喜欢花椒风味就接着继续下小料碟，如不喜欢过浓的花椒风味，等花椒激发出香味后将花椒粒去掉，保留锅底的油，再下小料碟","xhsLink":"🥔零失败酸辣土豆丝｜记住这4步，爽脆入味 是谁还炒不... http://xhslink.com/o/YG5pay3lK0  复制后打开【小红书】查看笔记！"}
{"_id":"33956e3d69beac2c0108f3d47d4fba5b","_openid":"oQVJx3ZG20jRC_OLd9ag7_DiZYm4","category":"凉菜","name":"凉拌芝麻菜","tips":"焯水时间不超过1min","update_time":{"$date":"2026-03-21T14:43:07.551Z"},"create_time":{"$date":"2026-03-21T14:33:16.435Z"},"images":["cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774103595103_egkxm.jpg","cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774103595108_jaacy.jpg","cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774103595110_l1kij.jpg","cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774103595111_dqkgj.jpg","cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774103595112_joh4w.jpg"],"ingredients":[{"amount":"250g","name":"芝麻菜"},{"amount":"","name":"蒜末"},{"amount":"1根","name":"小米辣"},{"amount":"","name":"白芝麻"}],"stepGroups":[{"steps":[{"desc":"焯水：芝麻菜洗净，在煮沸的热水中加入一小勺油，芝麻菜焯水45s后捞出，并沥干水分"},{"desc":"酱汁准备：\n小碗中放入蒜末、小米辣切丁、一小勺白芝麻\n淋入滚烫的热油，激发出香味\n加入1/2汤勺白糖、2汤勺生抽、1汤勺香醋、适量白胡椒粉"},{"desc":"将准备好的酱汁倒入沥干水分的芝麻菜中，搅拌均匀后摆盘"}],"title":"烹饪"}],"xhsLink":"凉拌芝麻菜 芝麻菜不仅营养非常丰富，也是卡路里比较... http://xhslink.com/o/8YJ0h9FoPAJ  复制后打开【小红书】查看笔记！"}
{"_id":"f0df711e69beb04f010c5c027efeb135","name":"蹄花萝卜汤","update_time":{"$date":"2026-03-23T05:12:00.882Z"},"xhsLink":"治愈美食 【老妈蹄花汤】还原经典味道 现熬原汤猪蹄，... http://xhslink.com/o/7fIjyiSz1PO  复制后打开【小红书】查看笔记！","category":"汤羹","stepGroups":[{"steps":[{"desc":"蘸料碟：两汤匙生抽，两汤匙油泼辣子，一汤匙保宁醋，一小块蒜泥，一根香菜末（白芝麻，花生碎），一汤匙花椒油，三汤匙凉白开，一点点糖，一点点盐，一点点蚝油，姜丝"},{"desc":"白萝卜切片泡水"}],"title":"备菜"},{"steps":[{"desc":"猪蹄冲洗后，切小块，加葱姜，花椒粒，冷水入锅，大火煮开撇沫"},{"desc":"转中小火，盖锅盖焖煮1-1.5h"},{"desc":"倒入白萝卜，盖锅盖继续焖煮30min"},{"desc":"出锅前加2小勺盐，撒上葱花"}],"title":"烹饪"}],"tips":"","_openid":"oQVJx3ZG20jRC_OLd9ag7_DiZYm4","create_time":{"$date":"2026-03-21T14:50:55.051Z"},"images":["cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774104653587_u9yvf.jpg"],"ingredients":[{"amount":"500g","name":"猪蹄"},{"amount":"250g","name":"白萝卜"},{"name":"葱花","amount":""},{"amount":"","name":"香菜"},{"amount":"","name":"蒜末"},{"amount":"1片","name":"生姜"},{"amount":"","name":"花椒油"},{"amount":"","name":"油泼辣子"},{"amount":"","name":"花椒粒"}]}
{"_id":"c3459b2a69bebb930108231a4774e525","_openid":"oQVJx3ZG20jRC_OLd9ag7_DiZYm4","create_time":{"$date":"2026-03-21T15:38:59.959Z"},"images":["cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774107538485_g5o85.jpg","cloud://cloud1-0g65hyz8b91894f3.636c-cloud1-0g65hyz8b91894f3-1412892826/recipes/1774107538487_jm1v8.jpg"],"stepGroups":[{"steps":[{"desc":"小料碟：蒜末和干辣椒切丁"},{"desc":"丝瓜去皮，切掉两头，切长条，浸水并加入小半勺盐，防止氧化变黑"},{"desc":"丝瓜沥干，拌淀粉、抓匀（此步骤不必须）"}],"title":"备菜"},{"steps":[{"desc":"热油爆香蒜干辣椒，倒入丝瓜翻炒至变软"},{"desc":"翻炒过程中加入半勺蚝油、1勺生抽，翻炒均匀"},{"desc":"大火爆炒十几秒，即可出锅"}],"title":"烹饪"}],"category":"素菜","ingredients":[{"name":"胖丝瓜","amount":"1根"},{"amount":"","name":"蒜末"},{"amount":"","name":"干辣椒🌶️"}],"name":"清炒丝瓜","tips":"","update_time":{"$date":"2026-03-23T07:26:42.22Z"},"xhsLink":""}
